{
  "name": "@sartoris/pi-engteam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "postbuild": "node --input-type=module -e \"import{cpSync}from'node:fs';cpSync('src/assets','dist/assets',{recursive:true,force:true});\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "install:extension": "bash scripts/install.sh",
    "uninstall:extension": "bash scripts/uninstall.sh",
    "engteam:install": "pnpm build && bash scripts/install.sh"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.8.5",
    "shell-quote": "^1.8.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.65.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.0",
    "@mariozechner/pi-coding-agent": "^0.67.0",
    "@mariozechner/pi-tui": "^0.67.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/shell-quote": "^1.7.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
